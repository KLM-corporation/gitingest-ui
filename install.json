{
  "run": [
    {
      "method": "fs.download",
      "params": {
        "url": "https://github.com/KLM-corporation/gitingest-ui/releases/latest/download/GitingestUI-Windows.zip",
        "dir": "build/Release"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": [
          "tar -xf GitingestUI-Windows.zip",
          "del GitingestUI-Windows.zip"
        ],
        "path": "build/Release"
      }
    },
    {
      "method": "notify",
      "params": {
        "html": "Installation finished. Click 'start' to run GitingestUI."
      }
    }
  ]
}
